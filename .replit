modules = ["nodejs-20", "python-3.12", "web"]

[deployment]
router = "application"
deploymentTarget = "autoscale"
run = ["sh", "-c", "node --enable-source-maps ./artifacts/api-server/dist/index.mjs"]
build = ["sh", "-c", "bash scripts/deploy-build.sh"]

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Telegram Bot"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "API Server"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Telegram Mini App"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "CRM Platform"

[[workflows.workflow]]
name = "Telegram Bot"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python3 supervisor.py"

[[workflows.workflow]]
name = "API Server"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "bash scripts/start-api.sh"

[[workflows.workflow]]
name = "Telegram Mini App"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm --filter @workspace/telegram-miniapp run dev"
waitForPort = 3000

[[workflows.workflow]]
name = "CRM Platform"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm --filter @workspace/crm-platform run dev"
waitForPort = 3001

[agent]
stack = "BEST_EFFORT_FALLBACK"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[[ports]]
localPort = 3000
externalPort = 3000

[[ports]]
localPort = 3001
externalPort = 3001

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 5173
externalPort = 3000

[[ports]]
localPort = 8080
externalPort = 8080

[[ports]]
localPort = 8081
externalPort = 8081

[[ports]]
localPort = 8083
externalPort = 80
exposeLocalhost = true

[[ports]]
localPort = 8090
externalPort = 3002

[[ports]]
localPort = 8091
externalPort = 3003

[[ports]]
localPort = 8092
externalPort = 5000

[[ports]]
localPort = 8093
externalPort = 5173

[[ports]]
localPort = 23873
externalPort = 3001

[nix]
channel = "stable-25_05"
packages = ["libxcrypt", "openssl"]

[userenv]

[userenv.shared]
PORT = "8080"

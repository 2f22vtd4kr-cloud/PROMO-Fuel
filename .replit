modules = ["nodejs-20", "python-3.12", "web", "bash"]

[deployment]
router = "application"
deploymentTarget = "autoscale"
run = ["bash", "scripts/start.sh"]
build = ["sh", "-c", "bash scripts/deploy-build.sh"]

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Telegram Bot"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Telegram Mini App"

[[workflows.workflow]]
name = "Telegram Bot"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "bash /home/runner/workspace/scripts/ensure-python-deps.sh && /home/runner/workspace/.pythonlibs/bin/python3 /home/runner/workspace/supervisor.py"

[[workflows.workflow]]
name = "Telegram Mini App"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "bash /home/runner/workspace/scripts/ensure-node-deps.sh && cd /home/runner/workspace/artifacts/telegram-miniapp && node node_modules/vite/bin/vite.js --config vite.config.ts --host 0.0.0.0"
waitForPort = 5000

[agent]
stack = "BEST_EFFORT_FALLBACK"
expertMode = true
integrations = ["javascript_gemini_ai_integrations:2.0.0", "javascript_anthropic_ai_integrations:2.0.0"]

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[[ports]]
localPort = 3000
externalPort = 4200

[[ports]]
localPort = 3001
externalPort = 3001

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 8080
externalPort = 8080

[[ports]]
localPort = 8090
externalPort = 3002

[[ports]]
localPort = 8091
externalPort = 3003

[[ports]]
localPort = 8092
externalPort = 5000

[[ports]]
localPort = 8093
externalPort = 5173

[[ports]]
localPort = 23873
externalPort = 3001

[nix]
channel = "stable-25_05"
packages = ["libxcrypt", "openssl"]

[userenv]

[userenv.shared]
PORT = "8080"

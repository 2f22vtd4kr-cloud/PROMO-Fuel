modules = ["nodejs-20", "python-3.12", "web"]

[deployment]
router = "application"
deploymentTarget = "autoscale"
run = ["bash", "scripts/start.sh"]
build = ["sh", "-c", "bash scripts/deploy-build.sh"]

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Telegram Bot"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Telegram Mini App"

[[workflows.workflow]]
name = "Telegram Bot"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python3 supervisor.py"

[[workflows.workflow]]
name = "Telegram Mini App"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd artifacts/telegram-miniapp && node /home/runner/workspace/node_modules/.pnpm/vite@7.3.5_@types+node@25.6.2_jiti@2.7.0_lightningcss@1.32.0_tsx@4.21.0_yaml@2.8.4/node_modules/vite/bin/vite.js --config vite.config.ts --host 0.0.0.0"
waitForPort = 5000

[agent]
stack = "BEST_EFFORT_FALLBACK"
expertMode = true
integrations = ["javascript_gemini_ai_integrations:2.0.0"]

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[[ports]]
localPort = 3000
externalPort = 4200

[[ports]]
localPort = 3001
externalPort = 3001

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 8080
externalPort = 8080

[[ports]]
localPort = 8082
externalPort = 3000
exposeLocalhost = true

[[ports]]
localPort = 8083
externalPort = 80
exposeLocalhost = true

[[ports]]
localPort = 8090
externalPort = 3002

[[ports]]
localPort = 8091
externalPort = 3003

[[ports]]
localPort = 8092
externalPort = 5000

[[ports]]
localPort = 8093
externalPort = 5173

[[ports]]
localPort = 23873
externalPort = 3001

[nix]
channel = "stable-25_05"
packages = ["libxcrypt", "openssl"]

[userenv]

[userenv.shared]
PORT = "8080"
